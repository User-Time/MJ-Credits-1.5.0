  <modification type="public" template="post_article_macros" modification_key="add_mjc_bonus_list" description="添加红包" execution_order="10" enabled="1" action="str_replace">
    <find><![CDATA[<xf:macro id="post_macros::post_last_edit" arg-post="{$post}" />]]></find>
    <replace><![CDATA[<xf:include template="public:mjc_charge_purchaser_list" />

<xf:if is="$post.Reward is not empty">
	<xf:include template="public:mjc_reward_user_list" />
</xf:if>
<xf:include template="public:mjc_red_envelope_list" />
<xf:if is="$post.isFirstPost()">	
	<xf:include template="public:mjc_bonus_list" />
	<xf:include template="public:mjc_bonus_receiver_list" />
</xf:if>
$0]]></replace>
  </modification>
  <modification type="public" template="post_macros" modification_key="add_action_delete_bonus" description="添加删除进行中的抢红包按钮" execution_order="10" enabled="1" action="str_replace">
    <find><![CDATA[<xf:if is="$post.canReport()">]]></find>
    <replace><![CDATA[<xf:if is="$post.getBonus() is not empty">
	<xf:if is="$xf.visitor.is_super_admin AND $post.isFirstPost()">
	<a href="{{ link('posts/deleteBonus', $post) }}"
	   class="actionBar-action actionBar-action--report"
	   data-xf-click="overlay">
		{{ phrase('删除红包') }}
	</a>
</xf:if>
</xf:if>

$0]]></replace>
  </modification>
  <modification type="public" template="post_macros" modification_key="mjc_charge_purchaser_list_post_macros" description="添加积分内容" execution_order="10" enabled="1" action="str_replace">
