    <replace><![CDATA[$0
<xf:include template="public:mjc_charge_purchaser_list" />

<xf:if is="$post.Reward is not empty">
	<xf:include template="public:mjc_reward_user_list" />
</xf:if>
<xf:include template="public:mjc_red_envelope_list" />
<xf:if is="$post.isFirstPost()">
	
	<xf:include template="public:mjc_bonus_list" />
	<xf:include template="public:mjc_bonus_receiver_list" />
</xf:if>
]]></replace>
  </modification>
  <modification type="public" template="post_macros" modification_key="red_envelope_to_post_macros" description="添加红包按钮" execution_order="10" enabled="1" action="str_replace">
