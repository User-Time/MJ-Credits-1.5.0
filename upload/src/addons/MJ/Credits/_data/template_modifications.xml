			<a href="{{ link('posts/redEnvelope', $post) }}"
			   class="actionBar-action actionBar-action--report"
			   data-xf-click="overlay">
				{{ phrase('mjc_envelope') }}
			</a>
		</xf:if>
	</xf:if>
</xf:if>
$0]]></replace>
  </modification>
