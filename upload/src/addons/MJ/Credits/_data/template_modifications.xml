  <modification type="public" template="thread_list_macros" modification_key="add_reward_prefix_in_thread_list_macros" description="添加悬赏状态" execution_order="10" enabled="1" action="str_replace">
    <find><![CDATA[<xf:if is="$thread.prefix_id">]]></find>
    <replace><![CDATA[<xf:if is="$thread.reward_amount > 0">
	<xf:if is="{$thread.Question.solution_user_id} == 0">
		<span class="label label--accent" dir="auto" data-xf-init="tooltip" title="悬赏中">赏</span>
		<xf:else />
		<span class="label label--primary" dir="auto" data-xf-init="tooltip" title="悬赏已完成">赏</span>
	</xf:if>
</xf:if>
$0]]></replace>
  </modification>
  <modification type="public" template="thread_view" modification_key="offer_a_reward_to_thread_view_type_question" description="添加悬赏金额显示" execution_order="10" enabled="1" action="str_replace">
    <find><![CDATA[<div class="block-outer"><xf:trim>]]></find>
    <replace><![CDATA[<xf:if is="$thread.reward_amount > 0">
	<xf:css src="mjc_overview.less" />
	<div class="block-outer-reward">
		<div class="buttonGroup">
			<button class="button--primary button">
				<xf:if is="{$thread.Question.solution_user_id} != '0'">
					悬赏已完成。金额为 {$thread.reward_amount|mjc_currency($thread.reward_currency_id)}
					<xf:else />
					<a href="{{ link('threads/reward-edit', $thread) }}" data-xf-click="overlay">悬赏：{$thread.reward_amount|mjc_currency($thread.reward_currency_id)}</a>
				</xf:if>
			</button>
		</div>
	</div>
</xf:if>
$0]]></replace>
